# Puppeteer Chrome 실행 경로 (로컬 개발 환경)
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux/Docker: /usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Puppeteer 내장 Chrome 다운로드 스킵 (시스템 Chrome 사용 시 필수)
PUPPETEER_SKIP_DOWNLOAD=true

# 배포 URL (Railway 헬스체크용, CI에서 RAILWAY_PUBLIC_URL secret으로 관리)
# RAILWAY_PUBLIC_URL=https://your-app.up.railway.app
